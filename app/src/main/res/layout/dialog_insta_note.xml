<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:fontFamily="@font/poppins_bold"
        android:text="Note"
        android:textColor="#00E676"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Input Teks Note -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Apa yang sedang kamu lakukan?"
        android:textColorHint="#888888"
        app:hintTextColor="#00E676"
        app:boxStrokeColor="#00E676">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etNoteText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:textColor="#FFFFFF" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Tombol Ambil Selfie -->
    <Button
        android:id="@+id/btnCaptureSelfie"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:backgroundTint="#333333"
        android:fontFamily="@font/poppins_bold"
        android:text="Tambahkan Foto"
        android:textColor="#FFFFFF" />

    <!-- Preview Selfie -->
    <ImageView
        android:id="@+id/ivSelfiePreview"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_gravity="center"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        android:scaleType="centerCrop"
        android:background="#2A2A2A"
        android:contentDescription="Preview Selfie" />

    <!-- Label hapus foto (visible saat foto sudah dipilih) -->
    <TextView
        android:id="@+id/tvRemovePhoto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="4dp"
        android:visibility="gone"
        android:text="✕  Hapus Foto"
        android:textColor="#FF5252"
        android:textSize="13sp"
        android:padding="4dp" />

</LinearLayout>