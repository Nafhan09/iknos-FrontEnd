<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_info_window"
        android:padding="16dp">

        <!-- Header: avatar + username -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivNoteAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@mipmap/ic_launcher_round"
                app:civ_border_width="2dp"
                app:civ_border_color="#00E676" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/tvNoteUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/note_loading"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_bold" />

                <TextView
                    android:id="@+id/tvNoteTimestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#AAAAAA"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Garis pemisah -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginBottom="12dp" />

        <!-- Foto note (tampil hanya jika ada) -->
        <ImageView
            android:id="@+id/ivNoteImage"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:visibility="gone"
            android:scaleType="centerCrop"
            android:background="#2A2A2A"
            android:contentDescription="Foto Insta Note"
            android:layout_marginBottom="10dp" />

        <!-- Teks note (tampil hanya jika ada) -->
        <TextView
            android:id="@+id/tvNoteText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#EEEEEE"
            android:gravity="center"
            android:textSize="13sp"
            android:visibility="gone"
            android:lineSpacingMultiplier="1.2" />

        <!-- Kordinat Pengguna -->
        <TextView
            android:id="@+id/tvNoteCoordinates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text=""
            android:textColor="#888888"
            android:textSize="11sp"
            android:visibility="gone" />

        <!-- Riwayat Waktu -->
        <TextView
            android:id="@+id/tvNoteTimeAgo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text=""
            android:textColor="#888888"
            android:textSize="11sp"
            android:textStyle="italic"
            android:visibility="gone" />

        <!-- Pesan jika tidak ada note sama sekali -->
        <LinearLayout
            android:id="@+id/layoutNoNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:paddingVertical="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="😶"
                android:textSize="28sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tidak tersedia note"
                android:textColor="#AAAAAA"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Tombol Hapus Keseluruhan Note (hanya untuk note milik sendiri) -->
        <Button
            android:id="@+id/btnDeleteNote"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="#FF1744"
            android:fontFamily="@font/poppins_bold"
            android:text="Hapus Note"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:visibility="gone" />

    </LinearLayout>
</LinearLayout>
